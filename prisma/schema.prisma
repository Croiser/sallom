generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  role             String            @default("admin")
  shopName         String?
  slug             String?           @unique
  status           String            @default("active")
  planId           String?
  phone            String?
  billingCycle     String?           @default("monthly")
  createdAt        DateTime          @default(now())
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  // Relations
  services         Service[]
  staff            Staff[]
  clients          Client[]
  appointments     Appointment[]
  settings         Setting?
  transactions     Transaction[]
  products         Product[]
  subscription     Subscription?
  whatsappSettings WhatsappSettings?
  whatsappMessages WhatsappMessage[]

  @@map("users")
}

model Service {
  id           String        @id @default(uuid())
  ownerUid     String
  name         String
  duration     Int
  price        Float
  owner        User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model Staff {
  id                   String        @id @default(uuid())
  ownerUid             String
  name                 String
  phone                String?
  commissionPercentage Float         @default(0)
  active               Boolean       @default(true)
  portfolio            String?       // JSON array of URLs
  owner                User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("staff")
}

model Client {
  id            String        @id @default(uuid())
  ownerUid      String
  name          String
  phone         String
  email         String?
  notes         String?
  loyaltyPoints Int           @default(0)
  loyaltyVisits Int           @default(0)
  createdAt     DateTime      @default(now())
  owner         User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  appointments  Appointment[]

  @@map("clients")
}

model Appointment {
  id          String   @id @default(uuid())
  ownerUid    String
  clientId    String
  clientName  String
  phone       String?
  serviceId   String
  serviceName String
  barberId    String
  barberName  String
  staffId     String?
  staffName   String?
  date        DateTime
  status      String   @default("scheduled")
  price       Float
  isFitIn     Boolean  @default(false)
  createdAt   DateTime @default(now())

  owner   User    @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model Setting {
  uid            String  @id
  slug           String? @unique
  logoUrl        String?
  address        String?
  addressNumber  String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  cnpj           String?
  description    String?
  phone          String?
  instagram      String?
  facebook       String?
  tiktok         String?
  timezone       String?
  businessHours  String? // JSON string
  whatsappConfig String? // JSON string
  holidays       String? // JSON string
  fidelityConfig String? // JSON string
  user           User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Transaction {
  id          String   @id @default(uuid())
  ownerUid    String
  type        String   // 'income' | 'expense'
  amount      Float
  description String
  date        DateTime
  category    String
  owner       User     @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Product {
  id       String @id @default(uuid())
  ownerUid String
  name     String
  price    Float
  cost     Float
  stock    Int
  category String
  owner    User   @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("products")
}

model Plan {
  id           String         @id
  name         String
  slug         String         @unique
  priceMonthly Float
  priceYearly  Float
  features     String?        // JSON string
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  uid              String   @id
  planId           String
  status           String
  billingCycle     String   @default("monthly")
  startDate        DateTime @default(now())
  endDate          DateTime
  currentPeriodEnd DateTime?
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [uid], references: [id], onDelete: Cascade)
  plan             Plan     @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model WhatsappSettings {
  uid            String  @id
  enabled        Boolean @default(false)
  apiKey         String?
  templates      String? // JSON string
  instanceName   String?
  instanceStatus String?
  batteryLevel   Int?
  user           User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  @@map("whatsapp_settings")
}

model WhatsappMessage {
  id              String   @id @default(uuid())
  ownerUid        String
  recipientNumber String?
  recipientName   String?
  content         String?
  type            String?
  status          String?
  externalId      String?
  createdAt       DateTime @default(now())
  owner           User     @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("whatsapp_messages")
}
