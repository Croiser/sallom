generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  role             String            @default("barber")
  shopName         String?
  slug             String?           @unique
  status           String            @default("active")
  planId           String?
  phone            String?
  billingCycle     String?           @default("monthly")
  createdAt        DateTime          @default(now())
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  // Relations
  staffId          String?           // New: Link login account to a staff member
  ownerId          String?           // New: Link professional to the Shop Owner
  services         Service[]
  staff            Staff[]
  clients          Client[]
  appointments     Appointment[]
  settings         Setting?
  transactions     Transaction[]
  products         Product[]
  subscription     Subscription?
  whatsappSettings WhatsappSettings?
  whatsappMessages  WhatsappMessage[]
  wallet            Wallet?
  anamnesis         Anamnesis[]
  sales             Sale[]

  @@map("users")
}

model Service {
  id           String        @id @default(uuid())
  ownerUid     String
  name         String
  duration     Int
  price        Float
  owner        User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  appointments Appointment[]
  saleItems    SaleItem[]
  comboItems   ComboItem[]

  @@map("services")
}

model Staff {
  id                   String        @id @default(uuid())
  ownerUid             String
  name                 String
  phone                String?
  commissionPercentage Float         @default(0)
  active               Boolean       @default(true)
  status               String        @default("Livre") // New: Livre, Ocupado, Em Intervalo
  notes                String?       // New: For staff records
  portfolio            String?       // JSON array of URLs
  owner                User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  sales                Sale[]
  appointments         Appointment[]

  @@map("staff")
}

model Client {
  id            String        @id @default(uuid())
  ownerUid      String
  name          String
  phone         String
  email         String?
  notes         String?
  loyaltyPoints Int           @default(0)
  loyaltyVisits Int           @default(0)
  pendingDebt   Float         @default(0)
  createdAt     DateTime      @default(now())
  owner         User          @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  anamnesis     Anamnesis[]
  sales         Sale[]

  @@map("clients")
}

model Appointment {
  id               String    @id @default(uuid())
  ownerUid         String
  clientId         String
  clientName       String
  phone            String?
  serviceId        String
  serviceName      String
  barberId         String
  barberName       String
  staffId          String?
  staffName        String?
  date             DateTime
  // Scheduling precision fields
  startTime        DateTime? // Exact start datetime (for overlap checks)
  endTime          DateTime? // Exact end datetime = startTime + totalDurationMin
  totalDurationMin Int?      // Total duration in minutes (sum of combo items or single service)
  // Recurrence & Combo
  recurrenceGroupId String?
  comboId          String?
  status           String    @default("scheduled")
  price            Float
  isFitIn          Boolean   @default(false)
  createdAt        DateTime  @default(now())

  // Cancellation & Workflow fields
  cancellationReason String?
  cancellationDate   DateTime?
  noShow             Boolean   @default(false)
  checkInAt          DateTime?
  finishedAt         DateTime?

  owner           User             @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff           Staff?           @relation(fields: [staffId], references: [id], onDelete: SetNull)
  recurrenceGroup RecurrenceGroup? @relation(fields: [recurrenceGroupId], references: [id], onDelete: SetNull)
  combo           ServiceCombo?    @relation(fields: [comboId], references: [id], onDelete: SetNull)

  @@index([staffId, startTime, endTime]) // Critical for overlap queries
  @@index([ownerUid, startTime])
  @@index([recurrenceGroupId])
  @@map("appointments")
}

// --- Recurrence ---

model RecurrenceGroup {
  id           String        @id @default(uuid())
  ownerUid     String
  staffId      String?
  frequency    String        // "weekly" | "biweekly" | "monthly"
  dayOfWeek    Int           // 0=Sun, 1=Mon, ... 6=Sat
  startDate    DateTime
  endDate      DateTime
  startTime    String        // "10:00" — time of day for the series
  serviceId    String?
  comboId      String?
  status       String        @default("active") // "active" | "cancelled"
  createdAt    DateTime      @default(now())
  appointments Appointment[]

  @@index([ownerUid])
  @@index([staffId])
  @@map("recurrence_groups")
}

// --- Combos ---

model ServiceCombo {
  id           String        @id @default(uuid())
  ownerUid     String
  name         String
  description  String?
  price        Float?
  createdAt    DateTime      @default(now())
  items        ComboItem[]
  appointments Appointment[]

  @@index([ownerUid])
  @@map("service_combos")
}

model ComboItem {
  id        String       @id @default(uuid())
  comboId   String
  serviceId String
  order     Int          // Execution order within combo
  combo     ServiceCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("combo_items")
}

model Setting {
  uid            String  @id
  slug           String? @unique
  logoUrl        String?
  address        String?
  addressNumber  String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  cnpj           String?
  description    String?
  phone          String?
  instagram      String?
  facebook       String?
  tiktok         String?
  timezone       String?
  businessHours  String? // JSON string
  whatsappConfig String? // JSON string
  holidays       String? // JSON string
  fidelityConfig String? // JSON string
  allowProfessionalViewAllAgendas Boolean @default(false)
  user           User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Transaction {
  id          String   @id @default(uuid())
  ownerUid    String
  type        String   // 'income' | 'expense'
  amount      Float
  description String
  date        DateTime
  category    String
  owner       User     @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Product {
  id       String @id @default(uuid())
  ownerUid String
  name     String
  price    Float
  cost     Float
  stock    Int
  category String
  owner    User   @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  @@map("products")
}

model Plan {
  id           String         @id
  name         String
  slug         String         @unique
  priceMonthly Float
  priceYearly  Float
  features     String?        // JSON string
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  uid              String   @id
  planId           String
  status           String
  billingCycle     String   @default("monthly")
  startDate        DateTime @default(now())
  endDate          DateTime
  currentPeriodEnd DateTime?
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [uid], references: [id], onDelete: Cascade)
  plan             Plan     @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model WhatsappSettings {
  uid            String  @id
  enabled        Boolean @default(false)
  apiKey         String?
  templates      String? // JSON string
  phoneNumberId  String?
  wabaId         String?
  wahaInstanceName String? @default("default")
  status         String  @default("disconnected") // connected, disconnected, connecting
  user           User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  @@map("whatsapp_settings")
}

model WhatsappMessage {
  id              String   @id @default(uuid())
  ownerUid        String
  recipientNumber String?
  recipientName   String?
  content         String?
  type            String?
  status          String?
  externalId      String?
  createdAt       DateTime @default(now())
  owner           User     @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("whatsapp_messages")
}

model Wallet {
  id           String              @id @default(uuid())
  ownerUid     String              @unique
  balance      Decimal             @default(0.00)
  currency     String              @default("BRL")
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
  user         User                @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String   // 'credit' | 'debit'
  category    String   // 'recharge' | 'automation_usage'
  amount      Decimal
  description String?
  createdAt   DateTime @default(now())

  @@map("wallet_transactions")
}

model Anamnesis {
  id           String   @id @default(uuid())
  clientId     String
  ownerUid     String
  procedure    String   @default("Geral")
  content      String   // JSON string with questions/answers
  signatureUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner        User     @relation(fields: [ownerUid], references: [id], onDelete: Cascade)

  @@map("anamnesis")
}

model Sale {
  id            String     @id @default(uuid())
  ownerUid      String
  clientId      String?
  staffId       String?
  totalAmount   Float
  paymentMethod String     // 'money' | 'card' | 'pix'
  createdAt     DateTime   @default(now())
  
  owner         User       @relation(fields: [ownerUid], references: [id], onDelete: Cascade)
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  staff         Staff?     @relation(fields: [staffId], references: [id], onDelete: SetNull)
  items         SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String?
  serviceId String?
  quantity  Int      @default(1)
  unitPrice Float
  totalPrice Float
  
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@map("sale_items")
}
