{
  "entities": {
    "User": {
      "title": "User",
      "description": "Barber shop owner or staff member",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "barber"] },
        "shopName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer of the barber shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "notes": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "Service": {
      "title": "Service",
      "description": "Service offered by the barber shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "price", "duration", "ownerUid"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled service for a client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "barberId": { "type": "string" },
        "barberName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "price": { "type": "number" },
        "ownerUid": { "type": "string" }
      },
      "required": ["clientId", "serviceId", "date", "status", "ownerUid"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record (income or expense)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["type", "amount", "date", "ownerUid"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Barbers or staff members in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "ownerUid": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "ownerUid"]
    },
    "ShopSettings": {
      "title": "ShopSettings",
      "description": "Configuration for the barber shop",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "timezone": { "type": "string" },
        "whatsappConfig": { "type": "object" }
      },
      "required": ["uid"]
    },
    "Holiday": {
      "title": "Holiday",
      "description": "Special days or holidays for the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "date", "ownerUid"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory products for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "price", "ownerUid"]
    },
    "Plan": {
      "title": "Plan",
      "description": "SaaS Subscription Plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "priceMonthly": { "type": "number" },
        "priceYearly": { "type": "number" },
        "features": { "type": "object" }
      },
      "required": ["name", "slug", "priceMonthly"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription record",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "past_due", "canceled"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "planId", "status"]
    },
    "WhatsAppMessage": {
      "title": "WhatsAppMessage",
      "description": "Log of sent WhatsApp messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "recipientNumber": { "type": "string" },
        "recipientName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["welcome", "reminder", "confirmation"] },
        "status": { "type": "string", "enum": ["queued", "sent", "delivered", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "recipientNumber", "content", "status"]
    },
    "WhatsAppSettings": {
      "title": "WhatsAppSettings",
      "description": "WhatsApp automation configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "enabled": { "type": "boolean" },
        "templates": { "type": "object" },
        "apiKey": { "type": "string" }
      },
      "required": ["uid", "enabled"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Customer list"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available services"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Booking schedule"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial records"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Shop staff"
    },
    "/settings/{uid}": {
      "schema": "ShopSettings",
      "description": "Shop configuration"
    },
    "/holidays/{holidayId}": {
      "schema": "Holiday",
      "description": "Shop holidays"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Available tiers"
    },
    "/subscriptions/{uid}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    },
    "/whatsapp_messages/{messageId}": {
      "schema": "WhatsAppMessage",
      "description": "WhatsApp message logs"
    },
    "/whatsapp_settings/{uid}": {
      "schema": "WhatsAppSettings",
      "description": "WhatsApp automation settings"
    }
  }
}
